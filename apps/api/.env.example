PORT=3000

# Neon/Postgres
# Example: postgresql://user:password@ep-...us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=YOUR_NEON_DATABASE_URL_HERE

# Google OAuth credentials
# Use a Google OAuth "Web application" client for local development.
# Redirect URI must be: http://localhost:3000/auth/google/callback
# Run: bun run auth:google (from apps/api) to get refresh token values.
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN_HERE
GOOGLE_API_KEY=

# Optional AI extraction fallback (used when regex parsing fails)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Booking workflow
MY_EMAIL=YOUR_EMAIL_HERE
BOOKING_TEST_EMAIL_QUERY=newer_than:30d from:directionsusa.com
BOOKING_TIMEZONE=UTC
APPROVAL_WATCHER_POLL_MINUTES=5
APPROVAL_WATCHER_QUERY=is:unread subject:(Booking Hold Created) newer_than:14d
